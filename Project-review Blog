        <span class="keyword">this</span>.name = name;
        <span class="keyword">this</span>.score = score;
    }
    <span class="comment">// getter, setter...</span>
}</code></pre>

      <h3>StudentManager.java — 실제 일을 하는 관리자</h3>
      <p>
        <code>ArrayList&lt;Student&gt;</code>로 학생 목록을 관리하며, 
        등록·조회·평균 계산·최고 점수 조회 로직을 담당합니다. 
        UI 코드와 분리했기 때문에 나중에 GUI나 웹으로 바꿔도 이 클래스는 그대로 재사용할 수 있습니다.
      </p>
      <pre><code><span class="keyword">public void</span> <span class="method">addStudent</span>(<span class="type">String</span> name, <span class="keyword">int</span> score) {
    students.add(<span class="keyword">new</span> <span class="type">Student</span>(name, score));
}

<span class="keyword">public double</span> <span class="method">calculateAverage</span>() {
    <span class="keyword">if</span> (students.isEmpty()) <span class="keyword">return</span> 0;
    <span class="keyword">int</span> sum = 0;
    <span class="keyword">for</span> (<span class="type">Student</span> s : students) {
        sum += s.getScore();
    }
    <span class="keyword">return</span> (<span class="keyword">double</span>) sum / students.size();
}</code></pre>

